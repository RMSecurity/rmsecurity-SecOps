# =============================================================================
# rmsecurity CCOS — Environment Configuration Template
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file. It is blocked by .gitignore.
# =============================================================================

# --- Operator identity -------------------------------------------------------
RMSEC_OPERATOR=your-name
RMSEC_OPERATOR_EMAIL=your@email.com
RMSEC_COMPANY=rmsecurity

# --- Engagement store --------------------------------------------------------
# Path to the encrypted volume where all client data lives.
# Mount your VeraCrypt or encrypted drive and set this path.
ENGAGEMENT_STORE=/path/to/encrypted/rmsecurity-engagements

# --- GitHub ------------------------------------------------------------------
GITHUB_ORG=rmsecurity
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Threat intelligence feeds -----------------------------------------------
# VirusTotal API (free tier: 4 requests/min, 500/day)
VT_API_KEY=

# Shodan API
SHODAN_API_KEY=

# Have I Been Pwned
HIBP_API_KEY=

# AbuseIPDB
ABUSEIPDB_API_KEY=

# SecurityTrails
SECURITYTRAILS_API_KEY=

# MISP instance (if self-hosted)
MISP_URL=
MISP_API_KEY=

# --- Notification integrations -----------------------------------------------
# Slack webhook for operational alerts
SLACK_WEBHOOK_URL=

# --- Report generation -------------------------------------------------------
# Path to report signing certificate (for PDF digital signatures)
REPORT_SIGNING_CERT=

# Company logo for reports (absolute path to PNG)
# Primary logo (dark background version) — used on report covers and headers
RMSEC_LOGO_PATH=/absolute/path/to/CCOS/10-CORPORATE/branding/logo/rmsecurity-logo-primary.png
RMSEC_LOGO_LIGHT_PATH=/absolute/path/to/CCOS/10-CORPORATE/branding/logo/rmsecurity-logo-light.png

# --- Cloud provider credentials (for cloud security assessments) -------------
# These should ideally use short-lived tokens, not permanent keys.
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=

# --- Docker ------------------------------------------------------------------
REGISTRY=ghcr.io
IMAGE_PREFIX=ghcr.io/rmsecurity
